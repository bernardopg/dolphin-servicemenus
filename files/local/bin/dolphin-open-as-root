#!/usr/bin/env bash
set -euo pipefail

target="${1:-$PWD}"
if [[ -d "$target" ]]; then
  dir="$target"
else
  dir="$(dirname -- "$target")"
fi

notify() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "Dolphin" "$1" >/dev/null 2>&1 || true
  fi
}

if ! command -v pkexec >/dev/null 2>&1; then
  notify "pkexec nao encontrado."
  exit 1
fi

display="${DISPLAY:-:0}"
xauthority="${XAUTHORITY:-$HOME/.Xauthority}"
xruntime="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
wayland_display="${WAYLAND_DISPLAY:-}"
qt_platform="${QT_QPA_PLATFORM:-wayland}"

exec pkexec env \
  DISPLAY="$display" \
  XAUTHORITY="$xauthority" \
  XDG_RUNTIME_DIR="$xruntime" \
  WAYLAND_DISPLAY="$wayland_display" \
  QT_QPA_PLATFORM="$qt_platform" \
  dolphin --new-window "$dir"
